max-visible=5
default-timeout=5000
ignore-timeout=0
history=1
max-history=50
anchor=top-right
layer=overlay
margin=15
padding=12,18
width=380
background-color=#000814CC
text-color=#00d7ff
border-size=1
border-color=#1f84ed
border-radius=6
font=JetBrainsMono Nerd Font 12
text-alignment=left
markup=1
icons=1
max-icon-size=64
icon-location=left
format=<b>%s</b>\n%b

[urgency=low]
border-color=#1f84ed
default-timeout=3000

[urgency=normal]
border-color=#1f84ed
default-timeout=5000

[urgency=critical]
border-color=#ff0055
default-timeout=0
font=JetBrainsMono Nerd Font 13
format=<b>⚠️ %s</b>\n%b

on-button-left=invoke-default-action
on-button-middle=exec makoctl dismiss
on-button-right=dismiss
