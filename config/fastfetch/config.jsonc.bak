{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "type": "file",
        "source": "~/.config/fastfetch/shark",
        "padding": {
            "top": 2,
            "left": 5
        },
        "color": {
            "1": "cyan",
            "2": "blue"
        }
    },
    "display": {
        "separator": " ➜  "
    },
    "modules": [
        {
        "type": "title",
        "color": {
            "user": "cyan",
            "at": "blue",
            "host": "cyan"
        },
        "padding": {
            "top": 2
        },

        },
        "separator",
        {
            "type": "os",
            "key": " ",
            "keyColor": "cyan"
        },
        {
            "type": "kernel",
            "key": " ",
            "keyColor": "cyan"
        },
        {
            "type": "packages",
            "key": " ",
            "keyColor": "cyan"
        },
        {
            "type": "wm",
            "key": " ",
            "keyColor": "cyan"
        },
        {
            "type": "terminal",
            "key": " ",
            "keyColor": "cyan"
        },
        {
            "type": "cpu",
            "key": " ",
            "keyColor": "blue"
        },
        {
            "type": "memory",
            "key": " ",
            "keyColor": "blue"
        },
        "break",
    ]
}
